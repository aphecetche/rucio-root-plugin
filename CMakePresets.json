{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "configure",
      "hidden": true,
      "cacheVariables": {
        "BUILD_SHARED_LIBS": {
          "type": "BOOL",
          "value": "ON"
        },
        "CMAKE_EXPORT_COMPILE_COMMANDS": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "dev",
      "inherits": "configure",
      "displayName": "Development Config",
      "description": "Development build",
      "binaryDir": "build-dev",
      "installDir": "install-dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "string",
          "value": "RelWithDebInfo"
        }
      }
    },
    {
      "name": "release",
      "inherits": "configure",
      "displayName": "Release Config",
      "description": "Release build for installation",
      "binaryDir": "build-release",
      "installDir": "install-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": {
          "type": "string",
          "value": "Release"
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 4,
      "targets": ["install"]
    },
    {
      "name": "dev",
      "configurePreset": "dev",
      "jobs": 4,
      "targets": ["install"]
    }
  ],
  "testPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "release",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        }
      ]
    },
    {
      "name": "dev",
      "steps": [
        {
          "type": "configure",
          "name": "dev"
        },
        {
          "type": "build",
          "name": "dev"
        }
      ]
    }
  ]
}
